{
  "name": "libreria-componentes-js",
  "version": "1.0.1",
  "description": "Librería de componentes UI con estilo glassmorphism",
  "type": "module",
  "main": "dist/libreria-componentes.umd.js",
  "module": "dist/libreria-componentes.es.js",
  "types": "dist/libreria-componentes.d.ts",
  "exports": {
    ".": {
      "types": "./dist/libreria-componentes.d.ts",
      "import": "./dist/libreria-componentes.es.js",
      "require": "./dist/libreria-componentes.umd.js"
    }
  },
  "files": [
    "dist/"
  ],
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "format": "prettier --write \"src/**/*.{js,css}\"",
    "format:check": "prettier --check \"src/**/*.{js,css}\"",
    "test": "vitest run",
    "test:watch": "vitest",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "prepublishOnly": "npm run build && npm run test",
    "prepare": "husky"
  },
  "keywords": [
    "ui",
    "components",
    "glassmorphism",
    "vanilla-js",
    "web-components"
  ],
  "author": "roa_no_bruh <roa_no_bruh@users.noreply.github.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/RoaYo/Libreria-Componentes-js.git"
  },
  "devDependencies": {
    "@chromatic-com/storybook": "^5.2.1",
    "@eslint/js": "^9.20.0",
    "@storybook/addon-a11y": "^10.4.0",
    "@storybook/addon-docs": "^10.4.0",
    "@storybook/addon-vitest": "^10.4.0",
    "@storybook/html": "^10.4.0",
    "@storybook/html-vite": "^10.4.0",
    "@vitest/browser": "^3.0.0",
    "@vitest/coverage-v8": "^3.0.0",
    "eslint": "^9.20.0",
    "eslint-plugin-storybook": "^10.4.0",
    "globals": "^15.15.0",
    "husky": "^9.1.0",
    "jsdom": "^29.1.1",
    "lint-staged": "^15.4.0",
    "playwright": "^1.60.0",
    "prettier": "^3.4.0",
    "storybook": "^10.4.0",
    "vite": "^6.2.0",
    "vitest": "^3.0.0"
  },
  "lint-staged": {
    "*.js": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.css": [
      "prettier --write"
    ]
  }
}
